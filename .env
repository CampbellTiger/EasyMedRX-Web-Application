EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=campbelltigerpro@gmail.com
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=EasyMedRX <easymedrx@gmail.com>

